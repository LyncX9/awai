# ==========================================
# LSTM Traffic Prediction System
# Environment Configuration Example
# ==========================================

# ------------------------------------------
# API Authentication & Security
# ------------------------------------------
# Comma-separated list of accepted API keys for inbound requests
# Leave empty to disable authentication (not recommended for production)
API_KEYS=your-inbound-api-key-here

# ------------------------------------------
# External Integrations (TomTom)
# ------------------------------------------
# Comma-separated list of TomTom API keys for live traffic ingestion
TOMTOM_API_KEYS=your-tomtom-api-key-here

# ------------------------------------------
# Model & Artifact Paths
# ------------------------------------------
# Optional: Specific model version to load (e.g., lstm-real-20260518-032721)
# If empty, the system will resolve the "latest" version automatically.
MODEL_VERSION=

# Paths to directories
DATASET_PATH=./artifacts/datasets
BUFFER_PATH=./artifacts/buffers
MODEL_PATH=./artifacts/models
LOG_DIR=./artifacts/logs

# ------------------------------------------
# Scheduler & Tuning
# ------------------------------------------
# Interval (in minutes) for fetching live data from TomTom
INGESTION_INTERVAL_MINUTES=15

# Time-to-Live (in seconds) for prediction cache
PREDICTION_CACHE_TTL_SECONDS=900

# ------------------------------------------
# Application Logic
# ------------------------------------------
# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
